// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER MODELS ============

model User {
  id            String    @id @default(cuid())
  discordId     String    @unique
  username      String
  discriminator String?
  avatar        String?
  banner        String?
  
  // Stats
  credits       Int       @default(0)
  level         Int       @default(1)
  experience    Int       @default(0)
  badges        String[]  @default([])
  
  // Settings
  language      String    @default("en")
  timezone      String?
  theme         String    @default("dark")
  
  // Premium
  isPremium     Boolean   @default(false)
  premiumUntil  DateTime?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSeen      DateTime  @default(now())
  
  // Relations
  guilds        GuildMember[]
  inventory     InventoryItem[]
  dailyRewards  DailyReward[]
  achievements  UserAchievement[]

  @@index([discordId])
  @@map("users")
}

// ============ GUILD MODELS ============

model Guild {
  id            String    @id @default(cuid())
  discordId     String    @unique
  name          String
  icon          String?
  owner         String
  
  // Configuration
  prefix        String    @default("!")
  language      String    @default("en")
  timezone      String?
  
  // Features
  automod       Boolean   @default(true)
  logging       Boolean   @default(true)
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  members       GuildMember[]
  settings      GuildSettings?
  logs          ModLog[]
  warnings      Warning[]

  @@index([discordId])
  @@map("guilds")
}

model GuildMember {
  id            String    @id @default(cuid())
  userId        String
  guildId       String
  
  // Roles & Permissions
  roles         String[]  @default([])
  
  // Guild Stats
  level         Int       @default(1)
  experience    Int       @default(0)
  joinCount     Int       @default(1)
  warns         Int       @default(0)
  
  // Timestamps
  joinedAt      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild         Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  warnings      Warning[]

  @@unique([userId, guildId])
  @@index([userId])
  @@index([guildId])
  @@map("guild_members")
}

model GuildSettings {
  id            String    @id @default(cuid())
  guildId       String    @unique
  
  // Channels
  modLogChannel String?
  welcomeChannel String?
  logsChannel   String?
  
  // Roles
  modRole       String?
  adminRole     String?
  memberRole    String?
  
  // Messages
  welcomeMessage String?
  leaveMessage  String?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  guild         Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("guild_settings")
}

// ============ INVENTORY & ECONOMY ============

model InventoryItem {
  id            String    @id @default(cuid())
  userId        String
  itemId        String
  quantity      Int       @default(1)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@map("inventory_items")
}

model Item {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  icon          String?
  price         Int       @default(0)
  rarity        String    @default("common")
  type          String    // "weapon", "armor", "consumable", etc.
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("items")
}

// ============ ACHIEVEMENTS & REWARDS ============

model Achievement {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String
  icon          String?
  points        Int       @default(10)
  
  createdAt     DateTime  @default(now())
  
  users         UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String    @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime  @default(now())
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model DailyReward {
  id            String    @id @default(cuid())
  userId        String
  day           Int
  creditsEarned Int
  completedAt   DateTime  @default(now())
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId])
  @@map("daily_rewards")
}

// ============ MODERATION ============

model Warning {
  id            String    @id @default(cuid())
  userId        String
  guildId       String
  moderatorId   String
  reason        String
  severity      String    @default("low") // "low", "medium", "high"
  
  createdAt     DateTime  @default(now())
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild         Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([guildId])
  @@map("warnings")
}

model ModLog {
  id            String    @id @default(cuid())
  guildId       String
  action        String    // "ban", "kick", "warn", "mute", etc.
  targetId      String
  moderatorId   String
  reason        String?
  duration      Int?      // in milliseconds
  
  createdAt     DateTime  @default(now())
  
  guild         Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([targetId])
  @@map("mod_logs")
}
